<?xml version='1.0' encoding='UTF-8'?>
<maps xmlns="https://dueca.tudelft.nl"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="https://dueca.tudelft.nl vsgobjects.xsd">

  <type name="ambient-light">
    <coordinates offset="0" size="3">color</coordinates>
    <coordinates offset="3" size="1">
      intensity
    </coordinates>
  </type>

  <type name="directional-light">
    <coordinates offset="0" size="3">color</coordinates>
    <coordinates offset="3" size="1">intensity</coordinates>
    <coordinates offset="4" size="3">phithetapsi</coordinates>
  </type>

  <type name="point-light">
    <coordinates offset="0" size="3">color</coordinates>
    <coordinates offset="3" size="1">intensity</coordinates>
    <coordinates offset="4" size="3">xyz</coordinates>
    <coordinates offset="7" size="1">span</coordinates>
  </type>

  <type name="spot-light">
    <coordinates offset="0" size="3">color</coordinates>
    <coordinates offset="3" size="1">intensity</coordinates>
    <coordinates offset="4" size="3">xyz</coordinates>
    <coordinates offset="7" size="1">span</coordinates>
    <coordinates offset="10" size="3">phithetapsi</coordinates>
    <coordinates offset="11" size="1">innerAngle</coordinates>
    <coordinates offset="12" size="1">outerAngle</coordinates>
  </type>

  <type name="static-absolute-transform">
    <coordinates offset="0" size="3">xyz</coordinates>
    <coordinates offset="3" size="3">phithetapsi</coordinates>
    <coordinates offset="6" size="3">scalexyz</coordinates>
  </type>

  <type name="static-matrix-transform">
    <coordinates offset="0" size="3">xyz</coordinates>
    <coordinates offset="3" size="3">phithetapsi</coordinates>
    <coordinates offset="6" size="3">scalexyz</coordinates>
  </type>

  <type name="absolute-transform">
    <coordinates offset="6" size="3">scalexyz</coordinates>
  </type>

  <type name="matrix-transform">
     <coordinates offset="6" size="3">scalexyz</coordinates>
  </type>

  <type name="model"></type>

  <type name="static-model"></type>

</maps>
     
