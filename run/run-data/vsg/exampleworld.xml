<?xml version='1.0' encoding='UTF-8'?>
<world xmlns="https://dueca.tudelft.nl"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="https://dueca.tudelft.nl vsgworld.xsd">

  <template id="carbase" type="static-absolute-transform">
    <coordinate name="xyz">
      0, 10, 3
    </coordinate>
    <coordinate name="scalexyz">
      1, 2, 3
    </coordinate>
    <coordinate name="phithetapsi">
      0, 0, 33
    </coordinate>
  </template>
	       
  <template id="car" type="model">
    <file>Defender.obj</file>
  </template>

  <template id="world" type="model">
    <file>lz.vsgt</file>
  </template>

  <!-- static, non-controlled objects -->

  <!-- transform node to the car location -->
  <static name="car1base" template-id="carbase"/>

  <!-- car model linked to the transform -->
  <static name="car1" template-id="car" parent="car1base"/>

  <!-- modified transform node -->
  <static name="car2base" template-id="carbase">
    <coordinate name="scalexyz"> 1, 1, 1 </coordinate>
    <coordinate name="xyz"> -50, 0, 0 </coordinate>
  </static>

  <!-- second instance of car -->
  <static name="car2" parent="car2base" type="model">
    <file>Defender.obj</file>
  </static>
  
</world>
